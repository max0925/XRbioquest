# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get these from: https://supabase.com/dashboard > Project Settings > API
#
# IMPORTANT:
# - NEXT_PUBLIC_SUPABASE_ANON_KEY must be a long JWT token starting with "eyJ"
# - NOT the short "sb_publishable_xxx" format
# - Copy the "anon" key from the API settings page

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MTU2NDAwMDB9.EXAMPLE_TOKEN_REPLACE_WITH_YOUR_ACTUAL_TOKEN
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.EXAMPLE_SERVICE_ROLE_KEY

# ============================================================================
# AI API KEYS
# ============================================================================
OPENAI_API_KEY=sk-proj-xxxxx
BLOCKADE_API_KEY=your-blockade-api-key
MESHY_API_KEY=msy_xxxxx

# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxx
STRIPE_PRICE_ADDON_ENV=price_xxxxx
STRIPE_PRICE_ADDON_MODEL=price_xxxxx

# ============================================================================
# OTHER SERVICES
# ============================================================================
SKETCHFAB_API_TOKEN=your-sketchfab-token
NEXT_PUBLIC_SITE_URL=http://localhost:3000
